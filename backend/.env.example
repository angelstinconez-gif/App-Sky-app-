# ───── Flask ─────
FLASK_ENV=development
FLASK_APP=wsgi.py
SECRET_KEY=cambia-esto-por-una-clave-segura-min-32-caracteres
JWT_SECRET_KEY=cambia-esto-tambien-otra-clave-segura

# ───── Database ─────
# Para desarrollo local con SQLite:
DATABASE_URL=sqlite:///skypv.db
